# ============================================
# WASCO Water Billing System - .gitignore
# ============================================

# ----------------------------
# Node.js / JavaScript
# ----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.local
.env.production
.env.development
.env.test
*.env

# ----------------------------
# Backend Specific
# ----------------------------
backend/node_modules/
backend/.env
backend/.env.*
backend/package-lock.json
backend/npm-debug.log*

# ----------------------------
# Frontend Specific
# ----------------------------
frontend/node_modules/
frontend/.env
frontend/.env.*
frontend/package-lock.json
frontend/dist/
frontend/.cache/

# React / Vite build outputs

frontend/dist/
frontend/.vite/

# ----------------------------
# Firebase
# ----------------------------
*firebase-adminsdk*.json
*serviceAccountKey*.json
*.pem
*.key

# ----------------------------
# IDE / Editor Files
# ----------------------------
# VSCode
.vscode/
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
*.code-workspace

# WebStorm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# ----------------------------
# Operating System Files
# ----------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Linux
*~
.directory
.directory-*

# ----------------------------
# Logs
# ----------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pm2-*.log

# ----------------------------
# Runtime data
# ----------------------------
pids/
*.pid
*.seed
*.pid.lock

# ----------------------------
# Coverage directory
# ----------------------------
coverage/
.nyc_output/

# ----------------------------
# Dependency directories
# ----------------------------
jspm_packages/

# ----------------------------
# Optional npm cache directory
# ----------------------------
.npm

# ----------------------------
# Optional eslint cache
# ----------------------------
.eslintcache

# ----------------------------
# Optional REPL history
# ----------------------------
.node_repl_history

# ----------------------------
# Output of 'npm pack'
# ----------------------------
*.tgz

# ----------------------------
# Yarn Integrity file
# ----------------------------
.yarn-integrity

# ----------------------------
# parcel-bundler cache
# ----------------------------
.cache/
.parcel-cache/

# ----------------------------
# Next.js build output
# ----------------------------
.next/
out/

# ----------------------------
# Nuxt.js build / generate output
# ----------------------------
.nuxt/
dist/

# ----------------------------
# Gatsby files
# ----------------------------
.cache/
public/

# ----------------------------
# Storybook build outputs
# ----------------------------
storybook-static/

# ----------------------------
# Temporal folders
# ----------------------------
.tmp/
.temp/
tmp/
temp/

# ----------------------------
# Database files
# ----------------------------
*.sqlite
*.sqlite3
*.db

# ----------------------------
# Upload/Download directories
# ----------------------------
uploads/
downloads/
temp_uploads/

# ----------------------------
# Certificates / Keys
# ----------------------------
*.p12
*.pfx
*.crt
*.key
*.pem
!*test.pem

# ----------------------------
# Docker
# ----------------------------
Dockerfile
docker-compose.yml
.docker/

# ----------------------------
# Backup files
# ----------------------------
*.backup
*.bak
*.old
*.orig

# ----------------------------
# Archive files
# ----------------------------
*.zip
*.tar.gz
*.rar
*.7z

# ----------------------------
# Project specific
# ----------------------------
# Production build files (but keep them in repo? usually not)
backend/build/
backend/dist/

# Secret configuration
config/secret/
private/
.secrets/

# Database migrations backup
migrations/*.backup

# Test outputs
test-results/
__tests__/coverage/

# Performance profiling
profile-*.json

# Screenshots (if any in project)
screenshots/
*.png
*.jpg
*.jpeg
*.gif
!docs/*.png

# Temporary user uploads
temp/
tmp_uploads/
.vercel
